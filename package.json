{
  "name": "zetsukae-launcher",
  "version": "1.0.0",
  "description": "A game launcher application built with Electron",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --windows"
  },
  "keywords": [
    "launcher",
    "games",
    "electron"
  ],
  "author": "Zetsukae",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.zetsukae.launcher",
    "productName": "Zetsukae Launcher",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "directories": {
      "buildResources": "src/assets"
    },
    "win": {
      "icon": "src/assets/icon/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "src/assets/icon/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}